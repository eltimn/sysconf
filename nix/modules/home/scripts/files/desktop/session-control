#!/usr/bin/env bash

# Session control script - launcher agnostic
# Works with rofi, fuzzel, or any dmenu-compatible launcher

# Configuration: Set LAUNCHER_CMD to override default
# Examples:
#   LAUNCHER_CMD="rofi -dmenu -p 'Session:'" ./session-control
#   LAUNCHER_CMD="fuzzel --dmenu -p 'Session:'" ./session-control

# Default launcher detection
if [ -z "$LAUNCHER_CMD" ]; then
  if command -v fuzzel &> /dev/null; then
    LAUNCHER_CMD="fuzzel --dmenu -p 'Session: '"
  elif command -v rofi &> /dev/null; then
    LAUNCHER_CMD="rofi -dmenu -p 'Session:'"
  else
    echo "Error: No launcher found. Install fuzzel or rofi, or set LAUNCHER_CMD." >&2
    exit 1
  fi
fi

# Define actions
ACTIONS="Logout
Reboot
Shutdown
Suspend
Lock"

# Show menu and get selection
SELECTION=$(echo -e "$ACTIONS" | eval "$LAUNCHER_CMD")

# Exit if nothing selected
[ -z "$SELECTION" ] && exit 0

# Execute action
case "$SELECTION" in
  "Logout")
    niri msg action quit
    ;;
  "Reboot")
    systemctl reboot
    ;;
  "Shutdown")
    systemctl poweroff
    ;;
  "Suspend")
    systemctl suspend
    ;;
  "Lock")
    # Check for common screen lockers
    if command -v swaylock &> /dev/null; then
      swaylock -f -c 000000
    elif command -v gtklock &> /dev/null; then
      gtklock
    else
      notify-send "Error" "No screen locker found. Install swaylock or gtklock."
      exit 1
    fi
    ;;
  *)
    echo "Unknown action: $SELECTION" >&2
    exit 1
    ;;
esac
